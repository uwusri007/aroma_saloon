# Server
PORT=5000
NODE_ENV=development

# Database (MySQL in Docker — npm run docker:up)
DB_HOST=localhost
DB_PORT=3307
DB_USER=root
DB_PASSWORD=salon_root_pass
DB_NAME=salon_booking

# JWT
JWT_SECRET=your_super_secret_jwt_key_change_in_production
JWT_EXPIRES_IN=7d

# Frontend URL (for CORS and email links)
FRONTEND_URL=http://localhost:3000

# PayPal (Sandbox)
PAYPAL_CLIENT_ID=your_paypal_client_id
PAYPAL_CLIENT_SECRET=your_paypal_client_secret
PAYPAL_MODE=sandbox

# Email (MailHog in Docker — view inbox at http://localhost:8026)
SMTP_HOST=localhost
SMTP_PORT=1026
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=Salon Booking <noreply@salon.local>

# Uploads
UPLOAD_DIR=uploads
